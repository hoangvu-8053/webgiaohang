@{
    ViewData["Title"] = "Báo cáo & Thống kê";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">📊 Dashboard - Báo cáo & Thống kê</h2>

    <!-- Thống kê tổng quan -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@ViewBag.TotalOrders</h4>
                            <p class="mb-0">📦 Tổng đơn hàng</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-shopping-cart fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@ViewBag.TotalRevenue.ToString("N0") ₫</h4>
                            <p class="mb-0">💰 Doanh thu giao hàng</p>
                            <small class="text-light">(Đã giao thành công)</small>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-money-bill-wave fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@ViewBag.TotalServiceFee.ToString("N0") ₫</h4>
                            <p class="mb-0">💼 Phí dịch vụ</p>
                            <small class="text-light">(30.000đ/đơn hàng đã vận chuyển)</small>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-hand-holding-usd fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@ViewBag.TotalRevenueWithFee.ToString("N0") ₫</h4>
                            <p class="mb-0">💵 Tổng doanh thu</p>
                            <small class="text-light">(Giao hàng + Phí dịch vụ)</small>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-chart-line fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@ViewBag.TotalCustomers</h4>
                            <p class="mb-0">👥 Tổng khách hàng</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4>@ViewBag.TotalShippers</h4>
                            <p class="mb-0">🚚 Tổng shipper</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-truck fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Thống kê tháng này -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>📈 Thống kê tháng này</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-4">
                            <h3 class="text-primary">@ViewBag.MonthlyOrders</h3>
                            <p>Đơn hàng</p>
                        </div>
                        <div class="col-4">
                            <h3 class="text-success">@ViewBag.MonthlyRevenue.ToString("N0") ₫</h3>
                            <p>Doanh thu giao hàng</p>
                        </div>
                        <div class="col-4">
                            <h3 class="text-warning">@ViewBag.MonthlyServiceFee.ToString("N0") ₫</h3>
                            <p>Phí dịch vụ</p>
                            <small class="text-muted">(Đã vận chuyển)</small>
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-12">
                            <h4 class="text-info">@ViewBag.MonthlyRevenueWithFee.ToString("N0") ₫</h4>
                            <p class="mb-0"><strong>Tổng doanh thu tháng</strong> <small class="text-muted">(Giao hàng + Phí dịch vụ)</small></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>📊 Thống kê theo trạng thái</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.StatusStats != null)
                    {
                        foreach (var stat in ViewBag.StatusStats)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@stat.Status</span>
                                <span class="badge bg-primary">@stat.Count</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Top shipper và sản phẩm -->
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>🏆 Top Shipper</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.TopShippers != null)
                    {
                        foreach (var shipper in ViewBag.TopShippers)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@shipper.ShipperName</span>
                                <span class="badge bg-success">@shipper.OrderCount đơn</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>🔥 Top Sản phẩm</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.TopProducts != null)
                    {
                        foreach (var product in ViewBag.TopProducts)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@product.Product</span>
                                <span class="badge bg-warning">@product.OrderCount đơn</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Biểu đồ -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5>📊 Biểu đồ doanh thu 7 ngày gần nhất</h5>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Nút điều hướng -->
    <div class="row mt-4">
        <div class="col-12 text-center">
            <a href="/Report/Orders" class="btn btn-primary me-2">
                📋 Báo cáo đơn hàng
            </a>
            <a href="/Report/Revenue" class="btn btn-success me-2">
                💰 Báo cáo doanh thu
            </a>
            <a href="/Report/Shipper" class="btn btn-info">
                🚚 Báo cáo shipper
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Lấy dữ liệu cho biểu đồ
        fetch('/Report/GetChartData')
            .then(response => response.json())
            .then(data => {
                const ctx = document.getElementById('revenueChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.map(item => item.Date),
                        datasets: [{
                            label: 'Doanh thu (VNĐ)',
                            data: data.map(item => item.Revenue),
                            borderColor: 'rgb(75, 192, 192)',
                            backgroundColor: 'rgba(75, 192, 192, 0.2)',
                            tension: 0.1
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            });
    </script>
} 