@{
    ViewData["Title"] = "Báo cáo doanh thu";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">💰 Báo cáo doanh thu</h2>
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        <strong>Lưu ý:</strong> Doanh thu giao hàng chỉ tính từ những đơn hàng có trạng thái "Đã giao thành công" (Delivered). Phí dịch vụ tính cho tất cả đơn hàng đã vận chuyển (Shipping + Delivered).
    </div>

    <!-- Bộ lọc -->
    <div class="card mb-4">
        <div class="card-header">
            <h5>🔍 Bộ lọc</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row">
                <div class="col-md-4">
                    <label class="form-label">📅 Từ ngày</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">📅 Đến ngày</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">
                        🔍 Lọc
                    </button>
                    <a href="/Report/Revenue" class="btn btn-secondary">
                        🔄 Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Thống kê tổng quan -->
    @if (ViewBag.RevenueData != null)
    {
        var revenueData = ViewBag.RevenueData as List<dynamic>;
        var totalRevenue = revenueData?.Sum(r => (decimal)r.Revenue) ?? 0;
        var totalServiceFee = revenueData?.Sum(r => (decimal)r.ServiceFee) ?? 0;
        var totalRevenueWithFee = revenueData?.Sum(r => (decimal)r.TotalRevenue) ?? 0;
        var totalOrders = revenueData?.Sum(r => (int)r.OrderCount) ?? 0;
        var avgRevenue = totalOrders > 0 ? totalRevenue / totalOrders : 0;

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h4>@totalRevenue.ToString("N0") ₫</h4>
                        <p class="mb-0">💰 Doanh thu giao hàng</p>
                        <small class="text-light">(Đã giao thành công)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <h4>@totalServiceFee.ToString("N0") ₫</h4>
                        <p class="mb-0">💼 Phí dịch vụ</p>
                        <small class="text-light">(30.000đ/đơn hàng đã vận chuyển)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h4>@totalRevenueWithFee.ToString("N0") ₫</h4>
                        <p class="mb-0">💵 Tổng doanh thu</p>
                        <small class="text-light">(Giao hàng + Phí dịch vụ)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h4>@totalOrders</h4>
                        <p class="mb-0">📦 Tổng đơn hàng</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Biểu đồ doanh thu -->
        <div class="card mb-4">
            <div class="card-header">
                <h5>📊 Biểu đồ doanh thu theo ngày</h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" width="400" height="200"></canvas>
            </div>
        </div>

        <!-- Bảng chi tiết -->
        <div class="card">
            <div class="card-header">
                <h5>📋 Chi tiết doanh thu theo ngày</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>📅 Ngày</th>
                                <th>📦 Số đơn hàng</th>
                                <th>💰 Doanh thu giao hàng</th>
                                <th>💼 Phí dịch vụ</th>
                                <th>💵 Tổng doanh thu</th>
                                <th>📊 Doanh thu trung bình</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (revenueData != null)
                            {
                                foreach (var item in revenueData)
                                {
                                    var date = (DateTime)item.Date;
                                    var orders = (int)item.OrderCount;
                                    var revenue = (decimal)item.Revenue;
                                    var serviceFee = (decimal)item.ServiceFee;
                                    var itemTotalRevenueWithFee = (decimal)item.TotalRevenue;
                                    var avgRevenuePerOrder = orders > 0 ? revenue / orders : 0;

                                    <tr>
                                        <td><strong>@date.ToString("dd/MM/yyyy")</strong></td>
                                        <td>
                                            <span class="badge bg-primary">@orders đơn</span>
                                        </td>
                                        <td>
                                            <strong class="text-success">@revenue.ToString("N0") ₫</strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-warning">@serviceFee.ToString("N0") ₫</span>
                                        </td>
                                        <td>
                                            <strong class="text-info">@itemTotalRevenueWithFee.ToString("N0") ₫</strong>
                                        </td>
                                        <td>@avgRevenuePerOrder.ToString("N0") ₫</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <h4>📭 Không có dữ liệu</h4>
            <p>Không tìm thấy dữ liệu doanh thu trong khoảng thời gian đã chọn.</p>
        </div>
    }

    <!-- Nút điều hướng -->
    <div class="text-center mt-4">
        <a href="/Report" class="btn btn-primary me-2">
            📊 Quay lại Dashboard
        </a>
        <a href="/Report/Orders" class="btn btn-info me-2">
            📋 Báo cáo đơn hàng
        </a>
        <a href="/Report/Shipper" class="btn btn-warning">
            🚚 Báo cáo shipper
        </a>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        @if (ViewBag.RevenueData != null)
        {
            <text>
            const ctx = document.getElementById('revenueChart').getContext('2d');
            const data = @Html.Raw(Json.Serialize(ViewBag.RevenueData));
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.map(item => new Date(item.date).toLocaleDateString('vi-VN')),
                    datasets: [{
                        label: 'Doanh thu giao hàng (VNĐ)',
                        data: data.map(item => item.revenue),
                        borderColor: 'rgb(75, 192, 192)',
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        tension: 0.1
                    }, {
                        label: 'Tổng doanh thu (VNĐ)',
                        data: data.map(item => item.totalRevenue),
                        borderColor: 'rgb(255, 99, 132)',
                        backgroundColor: 'rgba(255, 99, 132, 0.2)',
                        tension: 0.1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value.toLocaleString('vi-VN') + ' ₫';
                                }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    if (context.dataset.label.includes('Tổng doanh thu')) {
                                        return 'Tổng doanh thu: ' + context.parsed.y.toLocaleString('vi-VN') + ' ₫';
                                    } else {
                                        return 'Doanh thu giao hàng: ' + context.parsed.y.toLocaleString('vi-VN') + ' ₫';
                                    }
                                }
                            }
                        }
                    }
                }
            });
            </text>
        }
    </script>
} 