@{
    ViewData["Title"] = "Quên mật khẩu";
}
<h2 class="mb-4"><i class="fas fa-key me-2"></i>Quên mật khẩu</h2>
@if (ViewBag.Message != null)
{
    <div class="alert alert-success">@ViewBag.Message</div>
}
<form asp-action="ForgotPassword" method="post" class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Nhập email đã đăng ký</label>
        <input type="email" name="email" class="form-control" required />
        @if (ViewData.ModelState[""] != null)
        {
            <span class="text-danger">@ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage</span>
        }
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-1"></i> Gửi mã xác nhận</button>
        <a href="/Account/Login" class="btn btn-secondary ms-2">Quay lại đăng nhập</a>
    </div>
</form> 