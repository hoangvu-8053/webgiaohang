@{
    ViewData["Title"] = "Nhập mã xác nhận";
}
<h2 class="mb-4"><i class="fas fa-shield-alt me-2"></i>Nhập mã xác nhận</h2>
@if (ViewBag.Code != null)
{
    <div class="alert alert-info">Mã xác nhận của bạn là: <strong>@ViewBag.Code</strong></div>
}
<form asp-action="EnterResetCode" method="post" class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Nhập mã xác nhận</label>
        <input type="text" name="code" class="form-control" required maxlength="6" />
        @if (ViewData.ModelState[""] != null)
        {
            <span class="text-danger">@ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage</span>
        }
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary"><i class="fas fa-check me-1"></i> Xác nhận</button>
        <a href="/Account/ForgotPassword" class="btn btn-secondary ms-2">Quay lại</a>
    </div>
</form> 