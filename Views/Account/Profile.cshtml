@model webgiaohang.Models.User
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}
<h2 class="mb-4">Hồ sơ cá nhân</h2>
@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
<div class="row">
    <div class="col-md-4 text-center">
        <div class="mb-3">
            <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "/img/default-avatar.png" : Model.Avatar)" alt="avatar" class="rounded-circle shadow" style="width: 140px; height: 140px; object-fit: cover; border: 4px solid #2196f3; background: #fff;">
        </div>
        <form asp-action="Profile" asp-controller="Account" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <input type="file" name="avatar" class="form-control" accept="image/*" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Cập nhật ảnh đại diện</button>
        </form>
    </div>
    <div class="col-md-8">
        <form asp-action="Profile" asp-controller="Account" method="post" enctype="multipart/form-data">
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Tên đăng nhập</label>
                <div class="col-sm-9">
                    <input class="form-control" value="@Model.Username" readonly />
                </div>
            </div>
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Họ tên</label>
                <div class="col-sm-9">
                    <input class="form-control" name="fullName" value="@Model.FullName" />
                </div>
            </div>
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Email</label>
                <div class="col-sm-9">
                    <input class="form-control" name="email" value="@Model.Email" />
                </div>
            </div>
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Số điện thoại</label>
                <div class="col-sm-9">
                    <input class="form-control" name="phone" value="@Model.Phone" />
                </div>
            </div>
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Địa chỉ</label>
                <div class="col-sm-9">
                    <input class="form-control" name="address" value="@Model.Address" />
                </div>
            </div>
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Vai trò</label>
                <div class="col-sm-9">
                    <input class="form-control" value="@Model.Role" readonly />
                </div>
            </div>
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Trạng thái</label>
                <div class="col-sm-9">
                    @if (Model.IsApproved)
                    {
                        <span class="badge bg-success">Đã duyệt</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Chưa duyệt</span>
                    }
                </div>
            </div>
            <div class="mb-3 row">
                <label class="col-sm-3 col-form-label">Ngày tạo</label>
                <div class="col-sm-9">
                    <input class="form-control" value="@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")" readonly />
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Cập nhật hồ sơ</button>
        </form>
    </div>
</div> 