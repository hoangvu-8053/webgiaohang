@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}
<h2 class="mb-4"><i class="fas fa-lock me-2"></i>Đặt lại mật khẩu mới</h2>
@if (ViewBag.Message != null)
{
    <div class="alert alert-success">@ViewBag.Message</div>
}
<form asp-action="ResetPassword" method="post" class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Nhập mật khẩu mới</label>
        <input type="password" name="password" class="form-control" required minlength="6" />
        @if (ViewData.ModelState[""] != null)
        {
            <span class="text-danger">@ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage</span>
        }
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-success"><i class="fas fa-save me-1"></i> Đặt lại mật khẩu</button>
        <a href="/Account/Login" class="btn btn-secondary ms-2">Quay lại đăng nhập</a>
    </div>
</form> 