@model webgiaohang.Models.Review

@{
    ViewData["Title"] = "Đánh giá đơn hàng";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-star me-2"></i>
                        Đánh giá đơn hàng
                    </h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Lưu ý:</strong> Bạn chỉ có thể đánh giá đơn hàng đã giao thành công. 
                        Đánh giá của bạn sẽ giúp chúng tôi cải thiện dịch vụ.
                    </div>

                    <form asp-action="Review" method="post" id="reviewForm">
                        <input type="hidden" asp-for="OrderId" />

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold">
                                <i class="fas fa-star me-1"></i>Đánh giá tổng thể
                            </label>
                            <div class="rating-container">
                                <div class="stars">
                                    <input type="radio" id="star5" name="Rating" value="5" class="star-input" />
                                    <label for="star5" class="star-label">★</label>
                                    <input type="radio" id="star4" name="Rating" value="4" class="star-input" />
                                    <label for="star4" class="star-label">★</label>
                                    <input type="radio" id="star3" name="Rating" value="3" class="star-input" />
                                    <label for="star3" class="star-label">★</label>
                                    <input type="radio" id="star2" name="Rating" value="2" class="star-input" />
                                    <label for="star2" class="star-label">★</label>
                                    <input type="radio" id="star1" name="Rating" value="1" class="star-input" />
                                    <label for="star1" class="star-label">★</label>
                                </div>
                                <div class="rating-text mt-2">
                                    <span id="ratingText" class="text-muted">Chọn số sao để đánh giá</span>
                                </div>
                            </div>
                            <span asp-validation-for="Rating" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Comment" class="form-label fw-bold">
                                <i class="fas fa-comment me-1"></i>Nhận xét (không bắt buộc)
                            </label>
                            <textarea asp-for="Comment" class="form-control" rows="4" 
                                      placeholder="Chia sẻ trải nghiệm của bạn về dịch vụ giao hàng..."></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/Orders/Details/@Model.OrderId" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Quay lại
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-paper-plane me-1"></i>Gửi đánh giá
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.rating-container {
    text-align: center;
}

.stars {
    display: inline-block;
    direction: rtl;
}

.star-input {
    display: none;
}

.star-label {
    font-size: 2rem;
    color: #ddd;
    cursor: pointer;
    transition: color 0.2s;
}

.star-label:hover,
.star-label:hover ~ .star-label,
.star-input:checked ~ .star-label {
    color: #ffc107;
}

.rating-text {
    font-size: 1.1rem;
    font-weight: 500;
}
</style>

@section Scripts {
    <script>
        // Cập nhật text khi chọn sao
        const starInputs = document.querySelectorAll('.star-input');
        const ratingText = document.getElementById('ratingText');
        
        const ratingMessages = {
            1: 'Rất không hài lòng',
            2: 'Không hài lòng',
            3: 'Bình thường',
            4: 'Hài lòng',
            5: 'Rất hài lòng'
        };
        
        starInputs.forEach(input => {
            input.addEventListener('change', function() {
                const rating = this.value;
                ratingText.textContent = ratingMessages[rating];
                ratingText.className = 'text-primary fw-bold';
            });
        });
        
        // Validate form
        document.getElementById('reviewForm').addEventListener('submit', function(e) {
            const rating = document.querySelector('input[name="Rating"]:checked');
            if (!rating) {
                e.preventDefault();
                alert('Vui lòng chọn số sao để đánh giá!');
                return false;
            }
        });
    </script>
} 