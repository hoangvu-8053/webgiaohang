@{
    ViewData["Title"] = "Tra cứu đơn hàng";
}

<div class="container fade-in-up">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h2 class="mb-0">
                        <i class="fas fa-search me-2"></i>
                        Tra cứu đơn hàng
                    </h2>
                    <p class="mb-0 mt-2 opacity-75">Nhập mã đơn hàng hoặc số điện thoại để tra cứu</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Form -->
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="search-form">
                <!-- Info Alert -->
                <div class="alert alert-info mb-4">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Hướng dẫn tra cứu:</strong>
                    <ul class="mb-0 mt-2">
                        <li>Nhập mã đơn hàng (VD: DH123456) hoặc số điện thoại</li>
                        <li>Hệ thống sẽ tìm kiếm đơn hàng tương ứng</li>
                        <li>Bạn có thể tra cứu đơn hàng mà không cần đăng nhập</li>
                    </ul>
                </div>

                <!-- Error Messages -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Lỗi:</strong>
                        <ul class="mb-0 mt-2">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <!-- Search Form -->
                <form method="post" class="needs-validation" novalidate>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="trackingNumber" class="form-label">
                                <i class="fas fa-barcode me-2"></i>Mã đơn hàng
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="trackingNumber" 
                                   name="trackingNumber" 
                                   placeholder="VD: DH123456"
                                   value="@ViewBag.TrackingNumber">
                            <div class="form-text">Nhập mã đơn hàng để tra cứu</div>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="customerPhone" class="form-label">
                                <i class="fas fa-phone me-2"></i>Số điện thoại
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="customerPhone" 
                                   name="customerPhone" 
                                   placeholder="VD: 0123456789"
                                   value="@ViewBag.CustomerPhone">
                            <div class="form-text">Hoặc nhập số điện thoại</div>
                        </div>
                    </div>
                    
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-search me-2"></i>
                            Tra cứu đơn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="mb-3">
                        <i class="fas fa-lightbulb me-2"></i>
                        Bạn cần hỗ trợ?
                    </h5>
                    <div class="d-flex flex-wrap justify-content-center gap-3">
                        <a href="/Orders/Create" class="btn btn-success">
                            <i class="fas fa-plus me-2"></i>Tạo đơn hàng mới
                        </a>
                        <a href="/Account/Login" class="btn btn-info">
                            <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                        </a>
                        <a href="/Account/Register" class="btn btn-warning">
                            <i class="fas fa-user-plus me-2"></i>Đăng ký
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="fas fa-star me-2"></i>
                        Tính năng nổi bật
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <div class="text-center">
                                <i class="fas fa-clock fa-3x text-primary mb-3"></i>
                                <h5>Tra cứu 24/7</h5>
                                <p class="text-muted">Tra cứu đơn hàng bất cứ lúc nào, mọi nơi</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="text-center">
                                <i class="fas fa-shield-alt fa-3x text-success mb-3"></i>
                                <h5>Bảo mật thông tin</h5>
                                <p class="text-muted">Thông tin đơn hàng được bảo mật tuyệt đối</p>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="text-center">
                                <i class="fas fa-mobile-alt fa-3x text-warning mb-3"></i>
                                <h5>Responsive</h5>
                                <p class="text-muted">Tương thích với mọi thiết bị di động</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.opacity-75 {
    opacity: 0.75;
}

.gap-3 {
    gap: 1rem;
}

.btn-lg {
    padding: 1rem 2rem;
    font-size: 1.1rem;
}

.fa-3x {
    font-size: 3rem;
}

.form-label {
    font-weight: 600;
    color: #333;
    margin-bottom: 0.5rem;
}

.form-text {
    font-size: 0.875rem;
    color: #6c757d;
    margin-top: 0.25rem;
}

.needs-validation .form-control:invalid {
    border-color: #dc3545;
}

.needs-validation .form-control:valid {
    border-color: #198754;
}
</style>

<script>
// Form validation
(function() {
    'use strict';
    window.addEventListener('load', function() {
        var forms = document.getElementsByClassName('needs-validation');
        var validation = Array.prototype.filter.call(forms, function(form) {
            form.addEventListener('submit', function(event) {
                if (form.checkValidity() === false) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
    }, false);
})();

// Auto focus on first input
document.addEventListener('DOMContentLoaded', function() {
    var firstInput = document.querySelector('input[type="text"]');
    if (firstInput) {
        firstInput.focus();
    }
});
</script> 