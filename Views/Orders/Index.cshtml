@model IEnumerable<webgiaohang.Models.Order>

@{
    ViewData["Title"] = "Danh sách đơn hàng";
    var isSender = User.IsInRole("Sender");
    var isReceiver = User.IsInRole("Receiver");
    var isAdminOrStaff = User.IsInRole("Admin") || User.IsInRole("Staff");
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-0">
                        <i class="fas fa-list me-2"></i>
                        @if (isSender)
                        {
                            <span>Đơn hàng tôi gửi</span>
                        }
                        else if (isReceiver)
                        {
                            <span>Đơn hàng tôi nhận</span>
                        }
                        else
                        {
                            <span>Quản lý đơn hàng</span>
                        }
                    </h2>
                    @if (isSender)
                    {
                        <p class="text-muted mb-0">Theo dõi tất cả đơn hàng bạn đã gửi</p>
                    }
                    else if (isReceiver)
                    {
                        <p class="text-muted mb-0">Theo dõi tất cả đơn hàng bạn sẽ nhận</p>
                    }
                </div>
                <div>
                    <a href="/Orders/Create" class="btn btn-success">
                        <i class="fas fa-plus me-1"></i>Tạo đơn hàng mới
                    </a>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">Chưa có đơn hàng nào</h4>
                        @if (isSender)
                        {
                            <p class="text-muted">Bạn chưa có đơn hàng nào. Hãy tạo đơn hàng đầu tiên!</p>
                            <a href="/Orders/Create" class="btn btn-primary">
                                <i class="fas fa-plus me-1"></i>Tạo đơn hàng đầu tiên
                            </a>
                        }
                        else if (isReceiver)
                        {
                            <p class="text-muted">Bạn chưa có đơn hàng nào để nhận.</p>
                        }
                        else
                        {
                            <p class="text-muted">Chưa có đơn hàng nào trong hệ thống.</p>
                        }
                    </div>
                </div>
            }
            else
            {
                @if (!isSender && !isReceiver && !isAdminOrStaff)
                {
                    <div class="alert alert-danger mt-4">Bạn không có quyền xem lịch sử đơn hàng.</div>
                    return;
                }
                <!-- Thống kê nhanh cho người dùng -->
                @if (isSender || isReceiver)
                {
                    var totalOrders = Model.Count();
                    var pendingOrders = Model.Count(o => o.Status == "Pending");
                    var shippingOrders = Model.Count(o => o.Status == "Shipping");
                    var deliveredOrders = Model.Count(o => o.Status == "Delivered");
                    
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card bg-primary text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-shipping-fast fa-2x mb-2"></i>
                                    <h4>@totalOrders</h4>
                                    <p class="mb-0">Tổng đơn hàng</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-warning text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-clock fa-2x mb-2"></i>
                                    <h4>@pendingOrders</h4>
                                    <p class="mb-0">Đang chờ</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-info text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-truck fa-2x mb-2"></i>
                                    <h4>@shippingOrders</h4>
                                    <p class="mb-0">Đang giao</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-success text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-check-circle fa-2x mb-2"></i>
                                    <h4>@deliveredOrders</h4>
                                    <p class="mb-0">Đã giao</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="card shadow">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Mã đơn</th>
                                        @if (!isSender && !isReceiver)
                                        {
                                            <th>Người gửi</th>
                                            <th>Người nhận</th>
                                        }
                                        <th>Hàng hóa</th>
                                        <th>Giá trị</th>
                                        <th>Ngày đặt</th>
                                        <th>Trạng thái</th>
                                        @if (!isSender && !isReceiver)
                                        {
                                            <th>Shipper</th>
                                        }
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>#@item.Id</strong>
                                            @if (!string.IsNullOrEmpty(item.TrackingNumber))
                                            {
                                                <br><small class="text-muted">@item.TrackingNumber</small>
                                            }
                                        </td>
                                        @if (!isSender && !isReceiver)
                                        {
                                            <td>
                                                <div>
                                                    <strong>@item.SenderName</strong>
                                                    @if (!string.IsNullOrEmpty(item.SenderPhone))
                                                    {
                                                        <br><small class="text-muted">📞 @item.SenderPhone</small>
                                                    }
                                                    <br><small class="text-muted">📍 @(item.PickupAddress.Length > 25 ? item.PickupAddress.Substring(0, 25) + "..." : item.PickupAddress)</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@item.ReceiverName</strong>
                                                    @if (!string.IsNullOrEmpty(item.ReceiverPhone))
                                                    {
                                                        <br><small class="text-muted">📞 @item.ReceiverPhone</small>
                                                    }
                                                    <br><small class="text-muted">📍 @(item.DeliveryAddress.Length > 25 ? item.DeliveryAddress.Substring(0, 25) + "..." : item.DeliveryAddress)</small>
                                                </div>
                                            </td>
                                        }
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(item.ProductImagePath))
                                                {
                                                    <img src="@item.ProductImagePath" alt="Ảnh sản phẩm" style="width:48px;height:48px;object-fit:cover;border-radius:8px;box-shadow:0 1.5px 6px #bbb;" />
                                                }
                                                <div>
                                                    <strong>@item.Product</strong>
                                                    @if (!string.IsNullOrEmpty(item.ProductDescription))
                                                    {
                                                        <br><small class="text-muted">@(item.ProductDescription.Length > 30 ? item.ProductDescription.Substring(0, 30) + "..." : item.ProductDescription)</small>
                                                    }
                                                    @if (item.Weight.HasValue)
                                                    {
                                                        <br><small class="text-muted">⚖️ @item.Weight kg</small>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div>
                                                <strong class="text-primary">@item.TotalAmount.ToString("N0") ₫</strong>
                                                <br><small class="text-muted">Giá: @item.Price.ToString("N0") ₫</small>
                                                @if (item.ShippingFee > 0)
                                                {
                                                    <br><small class="text-muted">Phí: @item.ShippingFee.ToString("N0") ₫</small>
                                                }
                                                @if (item.InsuranceValue.HasValue && item.InsuranceValue > 0)
                                                {
                                                    <br><small class="text-info">🛡️ BH: @item.InsuranceValue.Value.ToString("N0") ₫</small>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div>
                                                <strong>@item.OrderDate.ToString("dd/MM/yyyy")</strong>
                                                <br><small class="text-muted">@item.OrderDate.ToString("HH:mm")</small>
                                            </div>
                                        </td>
                                        <td>
                                            @if (item.Status == "Pending") {
                                                <span class="badge bg-secondary fs-6">
                                                    <i class="fas fa-clock me-1"></i>Chờ xử lý
                                                </span>
                                            } else if (item.Status == "Shipping") {
                                                <span class="badge bg-primary fs-6">
                                                    <i class="fas fa-truck me-1"></i>Đang giao
                                                </span>
                                            } else if (item.Status == "Delivered") {
                                                <span class="badge bg-success fs-6">
                                                    <i class="fas fa-check-circle me-1"></i>Đã giao
                                                </span>
                                                @if (item.ActualDeliveryDate.HasValue)
                                                {
                                                    <br><small class="text-muted">@item.ActualDeliveryDate.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                                }
                                            } else if (item.Status == "Failed") {
                                                <span class="badge bg-danger fs-6">
                                                    <i class="fas fa-times-circle me-1"></i>Thất bại
                                                </span>
                                            } else {
                                                <span class="badge bg-dark fs-6">@item.Status</span>
                                            }
                                            
                                            @if (!string.IsNullOrEmpty(item.DeliveryType))
                                            {
                                                <br><small class="text-info">@item.DeliveryType</small>
                                            }
                                        </td>
                                        @if (!isSender && !isReceiver)
                                        {
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.ShipperName))
                                                {
                                                    <span class="badge bg-info">@item.ShipperName</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Chưa phân công</span>
                                                }
                                            </td>
                                        }
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="/Orders/Details/@item.Id" class="btn btn-outline-info btn-sm" title="Chi tiết">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (isAdminOrStaff)
                                                {
                                                    <a href="/Orders/Edit/@item.Id" class="btn btn-outline-primary btn-sm" title="Sửa">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a href="/Orders/Delete/@item.Id" class="btn btn-outline-danger btn-sm" title="Xóa">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                }
                                            </div>
                                            
                                            @if (isAdminOrStaff && ViewBag.Shippers != null)
                                            {
                                                <form asp-action="AssignShipper" asp-controller="Orders" method="post" class="mt-2">
                                                    <input type="hidden" name="orderId" value="@item.Id" />
                                                    <div class="input-group input-group-sm">
                                                        <select name="shipperName" class="form-select form-select-sm">
                                                            <option value="">--Chọn shipper--</option>
                                                            @foreach (var shipper in (IEnumerable<webgiaohang.Models.User>)ViewBag.Shippers)
                                                            {
                                                                if (item.ShipperName == shipper.Username)
                                                                {
                                                                    <option value="@shipper.Username" selected>@shipper.Username</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@shipper.Username">@shipper.Username</option>
                                                                }
                                                            }
                                                        </select>
                                                        <button type="submit" class="btn btn-warning btn-sm">
                                                            <i class="fas fa-truck"></i>
                                                        </button>
                                                    </div>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div> 
</div> 