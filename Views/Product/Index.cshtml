@model IEnumerable<webgiaohang.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📦 Quản lý sản phẩm</h2>
        <a href="/Product/Create" class="btn btn-success">
            ➕ Thêm sản phẩm mới
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var product in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="fas fa-image fa-3x text-muted"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Description</p>
                            <div class="row">
                                <div class="col-6">
                                    <strong class="text-danger">@product.Price.ToString("N0") ₫</strong>
                                </div>
                                <div class="col-6 text-end">
                                    <span class="badge bg-info">@product.Category</span>
                                </div>
                            </div>
                            <div class="mt-2">
                                <span class="badge @(product.StockQuantity > 0 ? "bg-success" : "bg-danger")">
                                    @(product.StockQuantity > 0 ? $"Còn {product.StockQuantity}" : "Hết hàng")
                                </span>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="btn-group w-100" role="group">
                                <a href="/Product/Edit/@product.Id" class="btn btn-primary btn-sm">
                                    ✏️ Sửa
                                </a>
                                <form asp-action="Delete" method="post" style="display: inline;">
                                    <input type="hidden" name="id" value="@product.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm" 
                                            onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">
                                        🗑️ Xóa
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <h4>📭 Chưa có sản phẩm nào</h4>
            <p>Hãy thêm sản phẩm đầu tiên!</p>
            <a href="/Product/Create" class="btn btn-primary">
                ➕ Thêm sản phẩm mới
            </a>
        </div>
    }
</div> 