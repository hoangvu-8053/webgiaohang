@model IEnumerable<webgiaohang.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
}
<h2 class="mb-4 mt-4"><i class="fas fa-users me-2 text-primary"></i>@ViewData["Title"]</h2>
<a href="/Admin/CreateUser" class="btn btn-success mb-4 ms-2" style="margin-top: 12px;"><i class="fas fa-user-plus me-1"></i> Tạo tài khoản mới</a>
@if (TempData["Message"] != null)
{
    <div class="alert alert-info animate__animated animate__fadeInDown">
        @TempData["Message"]
    </div>
}
<div class="row g-4">
    @foreach (var user in Model)
    {
    <div class="col-12 animate__animated animate__fadeInUp">
        <div class="card shadow border-0 mb-4 rounded-4 p-4 user-card position-relative" style="background: linear-gradient(120deg, #e0eafc 0%, #cfdef3 100%); min-height: 160px;">
            <div class="row align-items-center">
                <div class="col-md-2 text-center">
                    <div class="avatar-circle mb-2 mx-auto" style="width:64px;height:64px;display:flex;align-items:center;justify-content:center;border-radius:50%;font-size:2.2rem;background:#2196f3;border:4px solid #fff;box-shadow:0 2px 8px rgba(33,150,243,0.18);">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="fw-bold fs-5">@user.Username</div>
                    <div class="small text-muted">ID: @user.Id</div>
                </div>
                <div class="col-md-2 text-center">
                    <span class="fw-bold text-muted">Vai trò</span><br />
                <form asp-action="UpdateUserRole" asp-controller="Admin" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@user.Id" />
                        <select name="role" onchange="this.form.submit()" class="form-select form-select-sm d-inline-block w-auto mt-1">
                        @if (user.Role == "Admin") {
                                <option value="Admin" selected>🛡️ Admin</option>
                        } else {
                                <option value="Admin">🛡️ Admin</option>
                        }
                        @if (user.Role == "Staff") {
                                <option value="Staff" selected>👔 Staff</option>
                        } else {
                                <option value="Staff">👔 Staff</option>
                        }
                        @if (user.Role == "Sender") {
                                <option value="Sender" selected>📦 Sender</option>
                        } else {
                                <option value="Sender">📦 Sender</option>
                        }
                        @if (user.Role == "Receiver") {
                                <option value="Receiver" selected>📥 Receiver</option>
                        } else {
                                <option value="Receiver">📥 Receiver</option>
                        }
                        @if (user.Role == "Shipper") {
                                <option value="Shipper" selected>🚚 Shipper</option>
                        } else {
                                <option value="Shipper">🚚 Shipper</option>
                        }
                    </select>
                </form>
                </div>
                <div class="col-md-2 text-center">
                    <span class="fw-bold text-muted">Trạng thái</span><br />
                @if (user.IsApproved)
                {
                        <span class="badge bg-success mt-1 px-3 py-2 fs-6"><i class="fas fa-check-circle me-1"></i>Đã duyệt</span>
                }
                else
                {
                        <span class="badge bg-warning text-dark mt-1 px-3 py-2 fs-6"><i class="fas fa-hourglass-half me-1"></i>Chưa duyệt</span>
                    <form asp-action="ApproveUser" asp-controller="Admin" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-success btn-sm mt-1 px-3" onclick="return confirm('Duyệt tài khoản này?')"><i class="fas fa-check"></i> Duyệt</button>
                        </form>
                    }
                </div>
                <div class="col-md-4 text-center">
                    <span class="fw-bold text-muted">Thao tác</span><br />
                    <form asp-action="DeleteUser" asp-controller="Admin" method="post" style="display:inline">
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-danger btn-sm mt-1 px-3" onclick="return confirm('Xác nhận xóa?')"><i class="fas fa-trash"></i> Xóa</button>
                </form>
                <form asp-action="SetUserRole" asp-controller="Admin" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@user.Id" />
                        <select name="role" class="form-select form-select-sm d-inline-block w-auto mt-1">
                        @if (user.Role == "Admin") {
                                <option value="Admin" selected>🛡️ Admin</option>
                        } else {
                                <option value="Admin">🛡️ Admin</option>
                        }
                        @if (user.Role == "Staff") {
                                <option value="Staff" selected>👔 Staff</option>
                        } else {
                                <option value="Staff">👔 Staff</option>
                        }
                        @if (user.Role == "Sender") {
                                <option value="Sender" selected>📦 Sender</option>
                        } else {
                                <option value="Sender">📦 Sender</option>
                        }
                        @if (user.Role == "Receiver") {
                                <option value="Receiver" selected>📥 Receiver</option>
                        } else {
                                <option value="Receiver">📥 Receiver</option>
                        }
                        @if (user.Role == "Shipper") {
                                <option value="Shipper" selected>🚚 Shipper</option>
                        } else {
                                <option value="Shipper">🚚 Shipper</option>
                        }
                    </select>
                        <button type="submit" class="btn btn-secondary btn-sm mt-1 px-3">Cập nhật quyền</button>
                </form>
                @if (user.IsApproved)
                {
                        <a href="/Admin/RefreshUserAuth/@user.Id" class="btn btn-info btn-sm mt-1 px-3"><i class="fas fa-sync-alt"></i> Refresh Auth</a>
                }
                </div>
                <div class="col-md-2 text-center">
                    <a class="btn btn-info btn-sm mt-3 px-3" href="/Admin/Profile/@user.Id"><i class="fas fa-id-card"></i> Xem hồ sơ</a>
                </div>
            </div>
        </div>
    </div>
    }
</div>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<style>
.user-card { transition: box-shadow 0.2s, transform 0.2s; }
.user-card:hover { box-shadow: 0 6px 24px rgba(33,150,243,0.18), 0 1.5px 6px rgba(0,0,0,0.08); transform: translateY(-2px) scale(1.01); }
.avatar-circle { box-shadow: 0 2px 8px rgba(33,150,243,0.15); border: 4px solid #fff; }
</style> 