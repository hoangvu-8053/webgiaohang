@{
    ViewData["Title"] = "Trang chủ";
}
<link rel="stylesheet" href="/css/site.css" />
<div class="sonic-hero-section position-relative py-5" style="background: linear-gradient(120deg, #4f8cff 0%, #00e0ff 100%); min-height: 480px; overflow: hidden;">
    <div class="container position-relative z-2">
        <div class="row align-items-center justify-content-center">
            <div class="col-lg-6 text-center text-lg-start mb-4 mb-lg-0">
                <span class="sonic-logo-animated" style="display:inline-block;width:180px;height:180px;vertical-align:middle;cursor:pointer;">
                    <svg width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <radialGradient id="glow" cx="50%" cy="50%" r="60%">
                                <stop offset="0%" stop-color="#fff" stop-opacity="0.7" />
                                <stop offset="100%" stop-color="#2196F3" stop-opacity="1" />
                            </radialGradient>
                            <filter id="shadow" x="-40%" y="-40%" width="180%" height="180%">
                                <feDropShadow dx="0" dy="0" stdDeviation="8" flood-color="#00e0ff" flood-opacity="0.7" />
                            </filter>
                        </defs>
                        <circle cx="90" cy="90" r="80" fill="url(#glow)" filter="url(#shadow)"/>
                        <circle cx="90" cy="90" r="70" fill="#2196F3"/>
                        <text x="50%" y="56%" text-anchor="middle" fill="white" font-size="48" font-family="Arial Black,Arial,sans-serif" font-weight="bold" dominant-baseline="middle" style="letter-spacing:2px;">SONIC</text>
                        <animateTransform attributeName="transform" attributeType="XML" type="rotate" from="-5 90 90" to="5 90 90" dur="1.2s" repeatCount="indefinite" direction="alternate"/>
                    </svg>
                </span>
                <h1 class="display-3 fw-bold text-white mb-3 animate__animated animate__fadeInDown" style="text-shadow:0 2px 16px #00c3ff77;">
                    Giao Hàng Sonic
                </h1>
                <p class="lead text-white mb-4 fs-4 animate__animated animate__fadeInUp animate__delay-1s" style="text-shadow:0 1px 8px #00c3ff55;">
                    <i class="fas fa-bolt text-warning me-2"></i>
                    Siêu tốc - An toàn - Tiện lợi<br/>
                    Dịch vụ giao hàng hiện đại, lấy cảm hứng từ Sonic the Hedgehog!
                </p>
                <div class="d-flex flex-column flex-md-row gap-3 justify-content-center justify-content-md-start mb-4">
                    <a href="/Orders/Create" class="btn btn-warning btn-lg px-5 fw-bold shadow-lg sonic-btn-main">
                        <i class="fas fa-plus-circle me-2"></i>Tạo đơn hàng
                    </a>
                    <a href="/Orders/TrackOrder" class="btn btn-outline-light btn-lg px-5 fw-bold shadow-lg sonic-btn-sub">
                        <i class="fas fa-search me-2"></i>Tra cứu đơn hàng
                    </a>
                </div>
            </div>
            <!-- Trang trí động bên phải -->
            <div class="col-lg-6 d-none d-lg-block position-relative">
                <div class="sonic-decor">
                    <span class="sonic-bubble sonic-bubble-1"></span>
                    <span class="sonic-bubble sonic-bubble-2"></span>
                    <span class="sonic-bubble sonic-bubble-3"></span>
                    <span class="sonic-bubble sonic-bubble-4"></span>
                    <span class="sonic-bolt-icon"><i class="fas fa-bolt"></i></span>
                    <span class="sonic-bolt-icon2"><i class="fas fa-bolt"></i></span>
                </div>
            </div>
        </div>
    </div>
    <div class="sonic-wave-bg position-absolute top-0 start-0 w-100 h-100 z-1" style="pointer-events:none; opacity:0.15;"></div>
</div>

<!-- Lý do chọn Sonic -->
<div class="row justify-content-center mb-5">
    <div class="col-md-3 mb-4">
        <div class="card shadow-lg border-0 h-100 text-center animate__animated animate__fadeInUp" style="background: linear-gradient(135deg, #4f8cff 0%, #00e0ff 100%); color: #fff;">
                <div class="card-body">
                <i class="fas fa-shipping-fast fa-3x mb-3"></i>
                <h5 class="fw-bold">Tốc độ vượt trội</h5>
                <p>Giao hàng siêu tốc, lấy cảm hứng từ Sonic!</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card shadow-lg border-0 h-100 text-center animate__animated animate__fadeInUp animate__delay-1s" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: #fff;">
                <div class="card-body">
                <i class="fas fa-shield-alt fa-3x mb-3"></i>
                <h5 class="fw-bold">An toàn tuyệt đối</h5>
                <p>Đảm bảo hàng hóa luôn nguyên vẹn, bảo hiểm đầy đủ.</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card shadow-lg border-0 h-100 text-center animate__animated animate__fadeInUp animate__delay-2s" style="background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%); color: #222;">
                <div class="card-body">
                <i class="fas fa-smile-beam fa-3x mb-3"></i>
                <h5 class="fw-bold">Dịch vụ thân thiện</h5>
                <p>Hỗ trợ khách hàng tận tâm, chuyên nghiệp.</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-4">
        <div class="card shadow-lg border-0 h-100 text-center animate__animated animate__fadeInUp animate__delay-3s" style="background: linear-gradient(135deg, #43cea2 0%, #185a9d 100%); color: #fff;">
                <div class="card-body">
                <i class="fas fa-mobile-alt fa-3x mb-3"></i>
                <h5 class="fw-bold">Quản lý dễ dàng</h5>
                <p>Theo dõi đơn hàng mọi lúc, mọi nơi trên mọi thiết bị.</p>
            </div>
        </div>
    </div>
</div>

<!-- Quy trình giao hàng Sonic -->
<div class="row justify-content-center mb-5">
    <div class="col-md-4 mb-4">
        <div class="card shadow border-0 h-100 text-center animate__animated animate__fadeInUp" style="background: linear-gradient(120deg, #e0eafc 0%, #cfdef3 100%); color: #222;">
            <div class="card-body">
                <div class="step-circle bg-primary text-white mb-3">1</div>
                <h5 class="fw-bold">Tạo đơn hàng</h5>
                <p>Điền thông tin, chọn dịch vụ phù hợp.</p>
            </div>
        </div>
                </div>
    <div class="col-md-4 mb-4">
        <div class="card shadow border-0 h-100 text-center animate__animated animate__fadeInUp animate__delay-1s" style="background: linear-gradient(120deg, #d4fc79 0%, #96e6a1 100%); color: #222;">
            <div class="card-body">
                <div class="step-circle bg-success text-white mb-3">2</div>
                <h5 class="fw-bold">Giao hàng siêu tốc</h5>
                <p>Shipper nhận hàng và giao nhanh như Sonic.</p>
            </div>
        </div>
                </div>
    <div class="col-md-4 mb-4">
        <div class="card shadow border-0 h-100 text-center animate__animated animate__fadeInUp animate__delay-2s" style="background: linear-gradient(120deg, #fbc2eb 0%, #a6c1ee 100%); color: #222;">
            <div class="card-body">
                <div class="step-circle bg-warning text-dark mb-3">3</div>
                <h5 class="fw-bold">Nhận hàng & đánh giá</h5>
                <p>Khách nhận hàng, xác nhận và đánh giá dịch vụ.</p>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <h2 class="text-center fw-bold mb-5 fs-1">Khách hàng nói gì?</h2>
    <div class="row justify-content-center mb-5">
        <div class="col-md-4 mb-4">
            <div class="card shadow-lg border-0 h-100 text-center animate__animated animate__fadeInLeft" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: #fff;">
                <div class="card-body">
                    <img src="https://randomuser.me/api/portraits/men/32.jpg" class="rounded-circle mb-3" style="width:64px;height:64px;object-fit:cover;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                <blockquote class="blockquote mb-2">"Dịch vụ cực kỳ nhanh, shipper thân thiện, giá hợp lý!"</blockquote>
                    <footer class="blockquote-footer text-white-50">Nguyễn Văn A</footer>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow-lg border-0 h-100 text-center animate__animated animate__fadeInUp animate__delay-1s" style="background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%); color: #222;">
                <div class="card-body">
                    <img src="https://randomuser.me/api/portraits/women/44.jpg" class="rounded-circle mb-3" style="width:64px;height:64px;object-fit:cover;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                <blockquote class="blockquote mb-2">"Tôi rất hài lòng với tốc độ và sự an toàn của Giao Hàng Sonic."</blockquote>
                    <footer class="blockquote-footer text-dark">Trần Thị B</footer>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow-lg border-0 h-100 text-center animate__animated animate__fadeInRight animate__delay-2s" style="background: linear-gradient(135deg, #43cea2 0%, #185a9d 100%); color: #fff;">
                <div class="card-body">
                    <img src="https://randomuser.me/api/portraits/men/65.jpg" class="rounded-circle mb-3" style="width:64px;height:64px;object-fit:cover;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                <blockquote class="blockquote mb-2">"Ứng dụng dễ dùng, tra cứu đơn hàng tiện lợi, shipper rất nhiệt tình."</blockquote>
                    <footer class="blockquote-footer text-white-50">Lê Văn C</footer>
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="bg-light py-4 mt-5 border-top">
    <div class="container text-center">
        <span class="text-muted">&copy; 2025 Giao Hàng Sonic. Powered by Sonic the Hedgehog.</span>
    </div>
</footer>

<style>
.sonic-hero-section {
    position: relative;
    min-height: 480px;
    background: linear-gradient(120deg, #4f8cff 0%, #00e0ff 100%);
    overflow: hidden;
}
.sonic-wave-bg {
    background: url('https://www.transparenttextures.com/patterns/wavecut.png') repeat;
    opacity: 0.15;
}
.sonic-btn-main {
    background: linear-gradient(90deg, #ffe082 0%, #ffd740 100%);
    color: #222;
    border: none;
    box-shadow: 0 4px 24px #ffd74044;
    transition: all 0.2s;
}
.sonic-btn-main:hover {
    background: linear-gradient(90deg, #ffd740 0%, #ffe082 100%);
    color: #111;
    transform: translateY(-2px) scale(1.04);
}
.sonic-btn-sub {
    border: 2px solid #fff;
    color: #fff;
    background: transparent;
    transition: all 0.2s;
}
.sonic-btn-sub:hover {
    background: #fff;
    color: #00bfff;
    border-color: #00bfff;
    transform: translateY(-2px) scale(1.04);
}
.sonic-feature-card, .sonic-step-card {
    border-radius: 1.5rem;
    box-shadow: 0 2px 16px #00c3ff11;
    transition: box-shadow 0.2s, transform 0.2s;
}
.sonic-feature-card:hover, .sonic-step-card:hover {
    box-shadow: 0 8px 32px #00c3ff33;
    transform: translateY(-4px) scale(1.03);
}
.step-circle {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 1.5rem;
    font-weight: bold;
    margin: 0 auto;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.sonic-logo-animated svg {
    transition: filter 0.3s, transform 0.3s;
    filter: drop-shadow(0 0 32px #00e0ff88);
    animation: sonic-shake 2.2s cubic-bezier(0.23, 1, 0.32, 1) infinite alternate;
}
.sonic-logo-animated:hover svg {
    filter: drop-shadow(0 0 48px #ffd740cc) brightness(1.2);
    transform: scale(1.07) rotate(-3deg);
}
.sonic-decor {
    position: absolute;
    right: 10%;
    top: 30%;
    width: 320px;
    height: 320px;
    pointer-events: none;
}
.sonic-bubble {
    position: absolute;
    border-radius: 50%;
    opacity: 0.18;
    background: #fff;
    animation: sonic-bubble-float 6s infinite alternate;
}
.sonic-bubble-1 {
    width: 80px; height: 80px; left: 30px; top: 10px; animation-delay: 0s;
}
.sonic-bubble-2 {
    width: 40px; height: 40px; left: 180px; top: 60px; animation-delay: 1.2s;
}
.sonic-bubble-3 {
    width: 60px; height: 60px; left: 100px; top: 180px; animation-delay: 2.1s;
}
.sonic-bubble-4 {
    width: 30px; height: 30px; left: 220px; top: 200px; animation-delay: 0.7s;
}
.sonic-bolt-icon {
    position: absolute;
    left: 120px; top: 60px;
    font-size: 3rem;
    color: #ffd740;
    opacity: 0.7;
    animation: sonic-bolt-flicker 1.2s infinite alternate;
}
.sonic-bolt-icon2 {
    position: absolute;
    left: 200px; top: 180px;
    font-size: 2.2rem;
    color: #fffde7;
    opacity: 0.5;
    animation: sonic-bolt-flicker 1.7s infinite alternate-reverse;
}
</style>
<!-- Animate.css CDN for icon animation -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<!-- FontAwesome CDN for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
