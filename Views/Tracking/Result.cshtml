@model IEnumerable<webgiaohang.Models.Order>
@{
    ViewData["Title"] = "Kết quả tra cứu";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">✅ Kết quả tra cứu đơn hàng</h3>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>📦 Mã đơn hàng</th>
                                        <th>📤 Người gửi</th>
                                        <th>📥 Người nhận</th>
                                        <th>📦 Hàng hóa</th>
                                        <th>💰 Tổng tiền</th>
                                        <th>📅 Ngày đặt</th>
                                        <th>📊 Trạng thái</th>
                                        <th>🚚 Shipper</th>
                                        <th>📍 Vị trí hiện tại</th>
                                        <th>🔍 Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@(order.TrackingNumber ?? $"DH{order.Id:D6}")</strong>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@order.SenderName</strong>
                                                    <br><small class="text-muted">📞 @order.SenderPhone</small>
                                                    <br><small class="text-muted">📍 @(order.PickupAddress.Length > 20 ? order.PickupAddress.Substring(0, 20) + "..." : order.PickupAddress)</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@order.ReceiverName</strong>
                                                    <br><small class="text-muted">📞 @order.ReceiverPhone</small>
                                                    <br><small class="text-muted">📍 @(order.DeliveryAddress.Length > 20 ? order.DeliveryAddress.Substring(0, 20) + "..." : order.DeliveryAddress)</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@order.Product</strong>
                                                    @if (!string.IsNullOrEmpty(order.ProductDescription))
                                                    {
                                                        <br><small class="text-muted">@(order.ProductDescription.Length > 15 ? order.ProductDescription.Substring(0, 15) + "..." : order.ProductDescription)</small>
                                                    }
                                                </div>
                                            </td>
                                            <td>@order.TotalAmount.ToString("N0") ₫</td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                @if (order.Status == "Pending") {
                                                    <span class="badge bg-secondary">⏳ Chờ xử lý</span>
                                                } else if (order.Status == "Shipping") {
                                                    <span class="badge bg-primary">🚚 Đang giao</span>
                                                } else if (order.Status == "Delivered") {
                                                    <span class="badge bg-success">✅ Đã giao</span>
                                                } else if (order.Status == "Failed") {
                                                    <span class="badge bg-danger">❌ Thất bại</span>
                                                } else {
                                                    <span class="badge bg-dark">@order.Status</span>
                                                }
                                            </td>
                                            <td>@(order.ShipperName ?? "Chưa phân công")</td>
                                            <td>@(order.CurrentLocation ?? "N/A")</td>
                                            <td>
                                                <a href="/Tracking/Details/@order.Id" class="btn btn-info btn-sm">
                                                    👁️ Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <h4>⚠️ Không tìm thấy đơn hàng</h4>
                            <p>Vui lòng kiểm tra lại mã đơn hàng hoặc số điện thoại.</p>
                        </div>
                    }
                </div>
            </div>
            
            <div class="text-center mt-3">
                <a href="/Tracking" class="btn btn-primary">
                    🔍 Tra cứu đơn hàng khác
                </a>
            </div>
        </div>
    </div>
</div> 