@model IEnumerable<webgiaohang.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">📦 Đơn hàng của tôi</h3>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>📦 Mã đơn hàng</th>
                                        <th>📦 Sản phẩm</th>
                                        <th>💰 Tổng tiền</th>
                                        <th>📅 Ngày đặt</th>
                                        <th>📊 Trạng thái</th>
                                        <th>🚚 Shipper</th>
                                        <th>📍 Vị trí hiện tại</th>
                                        <th>🔍 Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@(order.TrackingNumber ?? $"DH{order.Id:D6}")</strong>
                                            </td>
                                            <td>@order.Product</td>
                                            <td><strong>@order.TotalAmount.ToString("N0") ₫</strong></td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                @if (order.Status == "Pending") {
                                                    <span class="badge bg-secondary">⏳ Pending</span>
                                                } else if (order.Status == "Shipping") {
                                                    <span class="badge bg-primary">🚚 Shipping</span>
                                                } else if (order.Status == "Delivered") {
                                                    <span class="badge bg-success">✅ Delivered</span>
                                                } else if (order.Status == "Failed") {
                                                    <span class="badge bg-danger">❌ Failed</span>
                                                } else {
                                                    <span class="badge bg-dark">@order.Status</span>
                                                }
                                            </td>
                                            <td>@(order.ShipperName ?? "Chưa phân công")</td>
                                            <td>@(order.CurrentLocation ?? "N/A")</td>
                                            <td>
                                                <a href="/Tracking/Details/@order.Id" class="btn btn-info btn-sm">
                                                    👁️ Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <h4>📭 Bạn chưa có đơn hàng nào</h4>
                            <p>Hãy tạo đơn hàng mới để bắt đầu!</p>
                            <a href="/Orders/Create" class="btn btn-primary">
                                ➕ Tạo đơn hàng mới
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div> 